        <sequence id="seq_Icelandic" spec="Sequence" taxon="Icelandic" totalcount="2" value=""/>
        <sequence id="seq_Norwegian" spec="Sequence" taxon="Norwegian" totalcount="2" value=""/>
        <sequence id="seq_Afrikaans" spec="Sequence" taxon="Afrikaans" totalcount="2" value=""/>
        <sequence id="seq_French" spec="Sequence" taxon="French" totalcount="2" value=""/>
